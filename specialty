<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HopSearch Dashboard</title>

<style>

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}


.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: #a8c8a0;
    padding: 10px 20px;
}

.logo {
    display: flex;
    align-items: center;
    gap: 10px;
}

.logo img { width: 40px; }
.home img { width: 25px; }


.container {
    display: flex;
    padding: 30px;
    gap: 30px;
    max-width: 1200px;
    margin: auto;
}

.main-content { flex: 2.5; }

.section-title {
    font-size: 28px;
    letter-spacing: 2px;
}

.sub-text {
    font-size: 14px;
    margin-bottom: 25px;
    color: #666;
}


.service-row {
    display: flex;
    align-items: flex-start;
    margin-bottom: 25px;
}


.icon-square img {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    object-fit: cover;
    background-color: #eee;
    margin-right: 15px;
}


.details-container { flex: 1; }

.location-label {
    font-size: 18px;
    margin-bottom: 8px;
}


.info-box {
    background-color: #c8e6c9;
    padding: 15px;
    border-radius: 6px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    font-size: 13px;
}

.info-box ul {
    padding-left: 20px;
}


.sidebar {
    flex: 1;
    background-color: #dcedc8;
    padding: 20px;
    border-radius: 6px;
    height: fit-content;
}

.sidebar-header {
    display: flex;
    justify-content: space-between;
    font-weight: bold;
    margin-bottom: 15px;
}

.medical-box h4 {
    text-align: center;
    font-size: 14px;
    text-transform: uppercase;
}

.sidebar hr {
    border: none;
    border-top: 2px solid #333;
    margin: 15px 0;
}

.sidebar ul {
    list-style: none;
}

.sidebar li {
    margin-bottom: 10px;
    font-size: 14px;
}


@media (max-width: 900px) {
    .container { flex-direction: column; }
    .info-box { grid-template-columns: 1fr; }
}

</style>
</head>

