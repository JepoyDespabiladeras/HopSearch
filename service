<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SERBISYO</title>

<style>


* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}


.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: #a8c8a0;
    padding: 10px 20px;
}

.logo {
    display: flex;
    align-items: center;
    gap: 10px;
}

.logo img {
    width: 40px;
}

.home img {
    width: 25px;
}


.dex {
    height: 250px;
    display: flex;
    justify-content: center;
    align-items: center;
}


.title {
    text-align: center;
    margin: 20px 0;
    font-weight: bold;
}


.services {
    display: flex;
    justify-content: space-around;
    background-color: #bcd6b5;
    padding: 30px;
}

.column {
    width: 30%;
    text-align: center;
}

.column h3 {
    margin-bottom: 15px;
}


.box {
    background-color: #d8e8d2;
    padding: 12px;
    margin: 10px 0;
    border-radius: 4px;
    transition: 0.3s;
}


.box:hover {
    background-color: #c4dcbc;
    transform: scale(1.05);
    cursor: pointer;
}


@media (max-width: 768px) {
    .services {
        flex-direction: column;
        align-items: center;
    }

    .column {
        width: 80%;
        margin-bottom: 20px;
    }

    .dex {
        height: 180px;
    }
}

</style>
</head>

<body>


<div class="header">
    <div class="logo">
        <img src="hoplog.png">
        <span>HopSearch</span>
    </div>

    <div class="home">
        <img src="balay.png">
    </div>
</div>


<div class="dex">
    <img src="doc.png" style="width:100%; height:100%; object-fit:cover;">
</div>


<div class="title">
    Learn more about Medical Services
</div>


<div class="services">

    <div class="column">
        <h3>Hospitals</h3>
        <div class="box">General Surgery</div>
        <div class="box">Neurology</div>
        <div class="box">Obstetrics & Gynecology</div>
        <div class="box">Diagnostic Imaging</div>
    </div>

    <div class="column">
        <h3>Clinics</h3>
        <div class="box">General Medicine</div>
        <div class="box">Optical Services</div>
        <div class="box">Medical Check-ups</div>
        <div class="box">Laboratory Diagnostics</div>
    </div>

    <div class="column">
        <h3>Centers</h3>
        <div class="box">Immunization</div>
        <div class="box">Maternal Care</div>
        <div class="box">Community Health Programs</div>
        <div class="box">Minor Diagnostics</div>
    </div>

</div>

</body>
</html>
